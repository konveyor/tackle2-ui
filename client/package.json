{
  "name": "@konveyor-ui/client",
  "version": "0.1.0",
  "type": "commonjs",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "analyze": "source-map-explorer 'dist/static/js/*.js'",
    "clean": "rimraf ./dist ./coverage",
    "prebuild": "npm run clean && npm run tsc -- --noEmit",
    "build": "NODE_ENV=production rspack build --config ./config/rspack.prod.mts",
    "build:dev": "NODE_ENV=development rspack build --config ./config/rspack.dev.mts",
    "start:dev": "NODE_ENV=development rspack dev --config ./config/rspack.dev.mts",
    "test": "NODE_ENV=test TZ=UTC jest --rootDir=. --config=./config/jest.config.ts",
    "format": "prettier --ignore-path ../.gitignore --ignore-path ../.prettierignore --ignore-unknown --write .",
    "format:check": "prettier --ignore-path ../.gitignore --ignore-path ../.prettierignore --ignore-unknown --check .",
    "lint": "eslint --max-warnings=21 .",
    "lint:fix": "eslint --max-warnings=21 --fix .",
    "tsc": "tsc -p ./tsconfig.json"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@hookform/resolvers": "^2.9.11",
    "@microlink/react-json-view": "^1.27.1",
    "@monaco-editor/react": "^4.7.0",
    "@patternfly/patternfly": "6.4.0",
    "@patternfly/react-charts": "8.4.1",
    "@patternfly/react-code-editor": "6.4.3",
    "@patternfly/react-core": "6.4.3",
    "@patternfly/react-icons": "6.4.0",
    "@patternfly/react-table": "6.4.3",
    "@patternfly/react-tokens": "6.4.0",
    "@tanstack/react-query": "^4.40.1",
    "@tanstack/react-query-devtools": "^4.40.1",
    "classnames": "^2.3.1",
    "dayjs": "^1.11.19",
    "fast-xml-parser": "^5.7.3",
    "file-saver": "^2.0.5",
    "git-url-parse": "^16.1.0",
    "i18next": "^25.3.0",
    "i18next-http-backend": "^3.0.2",
    "immer": "^10.2.0",
    "js-yaml": "^4.1.0",
    "jwt-decode": "^4.0.0",
    "lodash-es": "^4.17.21",
    "monaco-editor": "^0.52.2",
    "oidc-client-ts": "^3.5.0",
    "radash": "^12.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.4",
    "react-markdown": "^8.0.7",
    "react-measure": "^2.5.2",
    "react-oidc-context": "^3.3.1",
    "react-router-dom": "^5.2.0",
    "tinycolor2": "^1.6.0",
    "use-immer": "^0.11.0",
    "victory": "^37.3.6",
    "xmllint-wasm": "^5.0.0",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@rspack/cli": "^2.0.6",
    "@rspack/core": "^2.0.6",
    "@rspack/dev-server": "^2.0.3",
    "@rspack/plugin-react-refresh": "^2.0.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^29.5.4",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-measure": "^2.0.12",
    "@types/react-router-dom": "^5.1.7",
    "@types/tinycolor2": "^1.4.6",
    "browserslist": "^4.25.1",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-resolve": "^29.7.0",
    "jest-watch-typeahead": "^2.2.2",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "msw": "^1.3.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "react-refresh": "^0.17.0",
    "rspack-merge": "^1.0.1",
    "source-map-explorer": "^2.5.3",
    "style-loader": "^4.0.0",
    "ts-checker-rspack-plugin": "^1.3.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "msw": {
    "workerDirectory": "public"
  }
}
