# Application base URL (when commented out, uses the default URL: "http://localhost:9000")
# CYPRESS_BASE_URL=https://example.com

# Login credentials
CYPRESS_USER=admin
CYPRESS_PASSWORD=Dog8code

# Git credentials
CYPRESS_GIT_USER=gituser
CYPRESS_GIT_PASSWORD=gitpass123
CYPRESS_GIT_TOKEN=

# SVN credentials
CYPRESS_SVN_USER=svnuser
CYPRESS_SVN_PASSWORD=svnpass123

# Hub API credentials used by fixture shell scripts (cypress/fixtures/*.sh)
# These map to the same account as CYPRESS_USER/CYPRESS_PASSWORD above.
HUB_USER=admin
HUB_PASSWORD=Dog8code

# Only needed if authentication is enabled: Keycloak and initial user password
CYPRESS_INITIAL_PASSWORD=Passw0rd!
CYPRESS_KEYCLOAK_ADMIN_PASSWORD=admin123

# ---------------------------------------------------------------------------
# Self-signed certificate support (e.g. Kind cluster with nginx ingress)
# ---------------------------------------------------------------------------
# When the target environment uses a self-signed TLS certificate (common with
# local Kind/minikube clusters), two settings are required:
#
# 1. Allow Node.js (Cypress server-side) to connect without verifying the cert:
#    NODE_TLS_REJECT_UNAUTHORIZED=0
#
# 2. Pass chromeWebSecurity=false on the command line so the Electron browser
#    does not block cross-origin requests or reject the untrusted certificate:
#
#    npm run e2e:run:local -- --config chromeWebSecurity=false --spec "e2e/tests/ci.test.ts"
#
# Example .env for a local Kind cluster with auth enabled:
#
#    CYPRESS_BASE_URL=https://localhost:8443
#    CYPRESS_USER=admin
#    CYPRESS_PASSWORD=Passw0rd!
#    CYPRESS_INITIAL_PASSWORD=Passw0rd!
#    CYPRESS_KEYCLOAK_ADMIN_PASSWORD=admin123
#    NODE_TLS_REJECT_UNAUTHORIZED=0
